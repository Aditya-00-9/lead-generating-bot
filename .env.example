APP_NAME=kramaai-lead-monitor
APP_ENV=development
LOG_LEVEL=INFO
SENTRY_DSN=

# Random string (16+ chars). Required for GET /api/cron/daily-ingestion on Vercel; set the same value in Vercel project env as CRON_SECRET.
CRON_SECRET=

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=25

# App runtime (async). On Neon/Supabase you may use postgresql+asyncpg://... with ?ssl=require
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/kramaai_leads
# Alembic migrations (sync). If unset, CI falls back to DATABASE_URL (async URLs are coerced for migrate only).
SYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/kramaai_leads

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#kramaai-market-listening
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=kramaai-lead-monitor/1.0
REDDIT_SUBREDDITS=smallbusiness,fitnessbusiness,martialarts

GOOGLE_ALERT_RSS_URLS=https://www.google.com/alerts/feeds/0000/0000

KEYWORDS=MyStudio issues,MyStudio alternative,Pike13 problems,iClassPro complaints,Zen Planner issues,WellnessLiving complaints,Mindbody pricing,Jackrabbit support issue,Gymdesk alternatives,Vagaro billing issues
MAX_ITEMS_PER_QUERY=25
DUPLICATE_SIMILARITY_THRESHOLD=90
DUPLICATE_WINDOW_DAYS=14
ENABLE_PLACEHOLDER_SOURCES=true
REPORT_OUTPUT_DIR=reports
SCHEDULER_TIMEZONE=Asia/Kolkata
SCHEDULER_HOUR=19
SCHEDULER_MINUTE=30
